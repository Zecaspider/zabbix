        "cellOptions": { "type": "auto" },
        "filterable": false,
        "inspect": false
      },
      "mappings": [],
      "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": 0 } ] }
    },
    "overrides": [
      {
        "matcher": { "id": "byName", "options": "Início" },

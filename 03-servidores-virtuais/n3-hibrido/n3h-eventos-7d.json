  "options": {
    "cellHeight": "sm",
    "showHeader": true,
    "footer": { "show": false, "reducer": [ "sum" ], "fields": "" },
    "sortBy": []
  },
  "pluginVersion": "12.4.2",
  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT\n  FROM_UNIXTIME(e.clock) AS `Início`,\n  CASE WHEN er.r_eventid IS NULL THEN 'ACTIVO' ELSE 'resolvido' END AS `Estado`,\n  e.severity AS `Sev`,\n  e.name AS `Problema`,\n  CASE WHEN er.r_eventid IS NULL THEN UNIX_TIMESTAMP() - e.clock ELSE re.clock - e.clock END AS `Duração`,\n  CASE WHEN e.acknowledged = 1 THEN '✓' ELSE NULL END AS `Ack`\nFROM events e\nLEFT JOIN event_recovery er ON er.eventid = e.eventid\nLEFT JOIN events re ON re.eventid = er.r_eventid\nWHERE e.source = 0 AND e.object = 0 AND e.value = 1\n  AND e.clock > UNIX_TIMESTAMP() - 7*86400\n  AND e.objectid IN (\n    SELECT DISTINCT f.triggerid FROM functions f\n    JOIN items i ON i.itemid = f.itemid\n    JOIN hosts h ON h.hostid = i.hostid\n    WHERE h.host = '$hostid'\n  )\nORDER BY (er.r_eventid IS NULL) DESC, e.clock DESC\nLIMIT 50",
      "refId": "A",
      "sql": { "columns": [ { "parameters": [], "type": "function" } ], "groupBy": [ { "property": { "type": "string" }, "type": "groupBy" } ], "limit": 50 }
    }
  ]
}

  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT * FROM (\n  SELECT h.host AS `VM`, h.name AS `Nome`,\n    (SELECT ip FROM interface WHERE hostid=h.hostid AND main=1 AND type=1 LIMIT 1) AS `IP`,\n    (SELECT (SELECT value FROM history hh WHERE hh.itemid=i.itemid ORDER BY clock DESC LIMIT 1)\n       FROM items i WHERE i.hostid=h.hostid AND i.key_='system.cpu.util' LIMIT 1) AS `CPU`,\n    (SELECT (SELECT value FROM history hh WHERE hh.itemid=i.itemid ORDER BY clock DESC LIMIT 1)\n       FROM items i WHERE i.hostid=h.hostid AND i.key_='vm.memory.util' LIMIT 1) AS `RAM`,\n    (SELECT MAX(lv.val) FROM (\n       SELECT (SELECT value FROM history hh WHERE hh.itemid=i.itemid ORDER BY clock DESC LIMIT 1) AS val\n       FROM items i WHERE i.hostid=h.hostid AND i.key_ LIKE 'vfs.fs.size[%,pused]'\n    ) lv) AS `Disco`,\n    (SELECT COUNT(DISTINCT t.triggerid) FROM triggers t\n       JOIN functions f ON f.triggerid=t.triggerid JOIN items i2 ON i2.itemid=f.itemid\n       WHERE i2.hostid=h.hostid AND t.value=1 AND t.status=0) AS `Triggers`,\n    (SELECT t3.description FROM triggers t3\n       JOIN functions f3 ON f3.triggerid=t3.triggerid JOIN items i4 ON i4.itemid=f3.itemid\n       WHERE i4.hostid=h.hostid AND t3.value=1 AND t3.status=0\n       ORDER BY t3.priority DESC, t3.lastchange DESC LIMIT 1) AS `Problema`\n  FROM hosts h\n  JOIN host_tag ht ON ht.hostid=h.hostid AND ht.tag='servico'\n  WHERE ht.value = (SELECT ht2.value FROM hosts h2\n                    JOIN host_tag ht2 ON ht2.hostid=h2.hostid AND ht2.tag='servico'\n                    WHERE h2.name='${app}' LIMIT 1)\n    AND h.status=0 AND h.host NOT LIKE 'app-%'\n) x\nORDER BY `Triggers` DESC, GREATEST(COALESCE(`CPU`,0),COALESCE(`RAM`,0),COALESCE(`Disco`,0)) DESC",
      "refId": "A",
      "sql": { "columns": [ { "parameters": [], "type": "function" } ], "groupBy": [ { "property": { "type": "string" }, "type": "groupBy" } ], "limit": 50 }
    }
  ]

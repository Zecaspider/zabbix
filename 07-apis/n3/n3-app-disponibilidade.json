            "1": {
              "text": "FORA DO AR",
              "color": "red",
              "index": 1
            }
          }
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]
      }
    },
    "overrides": [
      {
        "matcher": { "id": "byRegexp", "options": ".*" },
        "properties": [
          { "id": "displayName", "value": " " }
        ]
      }
    ]
  },
  "options": {
    "showValue": "never",
    "rowHeight": 0.85,
    "mergeValues": true,
    "alignValue": "left",
    "legend": {
      "showLegend": false

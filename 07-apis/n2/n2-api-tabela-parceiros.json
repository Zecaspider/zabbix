      },
      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT `Host/App`, Servico, Problemas,\n  CASE WHEN DiasNum IS NULL THEN ''\n       WHEN DiasNum = 0 THEN 'hoje'\n       WHEN DiasNum = 1 THEN 'há 1 dia'\n       ELSE CONCAT('há ', DiasNum, ' dias') END AS `Em falha há`,\n  Estado, AppLink FROM (\n  SELECT\n    REPLACE(h.name, ' - Monitor da URL', '') AS `Host/App`,\n    h.name AS AppLink,\n    COALESCE(MAX(CASE WHEN ht.tag='servico' THEN ht.value END), '') AS Servico,\n    (SELECT COUNT(DISTINCT t2.triggerid) FROM triggers t2\n       INNER JOIN functions f2 ON f2.triggerid = t2.triggerid\n       INNER JOIN items i2 ON i2.itemid = f2.itemid\n       WHERE i2.hostid = h.hostid AND t2.value = 1 AND t2.status = 0) AS Problemas,\n    (SELECT ROUND((UNIX_TIMESTAMP() - MIN(t3.lastchange)) / 86400) FROM triggers t3\n       INNER JOIN functions f3 ON f3.triggerid = t3.triggerid\n       INNER JOIN items i3 ON i3.itemid = f3.itemid\n       WHERE i3.hostid = h.hostid AND t3.value = 1 AND t3.status = 0) AS DiasNum,\n    COALESCE((SELECT MIN(CASE\n                WHEN t4.description LIKE '%[L1]%' THEN 1\n                WHEN t4.description LIKE '%[L2]%' THEN 2\n                WHEN t4.description LIKE '%[L3]%' THEN 3\n                ELSE 4 END)\n       FROM triggers t4\n       INNER JOIN functions f4 ON f4.triggerid = t4.triggerid\n       INNER JOIN items i4 ON i4.itemid = f4.itemid\n       WHERE i4.hostid = h.hostid AND t4.value = 1 AND t4.status = 0), 5) AS Estado\n  FROM hosts h\n  INNER JOIN hosts_groups hg ON h.hostid = hg.hostid\n  LEFT JOIN host_tag ht ON h.hostid = ht.hostid\n  WHERE hg.groupid = 663\n  AND h.status = 0\n  AND h.hostid IN (SELECT hostid FROM host_tag WHERE tag = 'tipo' AND value = 'parceiro')\n  GROUP BY h.hostid, h.host, h.name\n) sub\nORDER BY Estado ASC, DiasNum DESC, `Host/App` ASC",
      "refId": "A",
      "sql": {
        "columns": [

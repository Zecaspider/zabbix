{
  "dashboardUid": "rede-n4-agencia",
  "dashboardTitle": "N4 · Agência — Detalhe",
  "folderUid": "rede-seg-agencias",
  "datasource": "ffo8sp8zllog0e",
  "notes": "Dashboard por agência (router = agência). Variáveis passadas pelo N3 via URL.",
  "anchor": {
    "datasource": {
      "type": "alexanderzobnin-zabbix-datasource",
      "uid": "ffo8sp8zllog0e"
    },
    "group": {
      "filter": "HG_DC_ROUTERS"
    },
    "host": {
      "filter": "DC1-RTE-WAN-INT"
    },
    "item": {
      "filter": "ICMP ping"
    }
  },
  "notes_anchor": "Âncora na REDE (host core sempre UP), não no router da agência — senão o header (utils) some quando a agência está DOWN. Datasource da âncora == datasource do painel (Network) para evitar mismatch (B-03).",
  "drilldownFrom": "rede-n3-agencias",
  "drilldownUrl": "/d/rede-n4-agencia?var-group=HG_AGENCIAS_ROUTERS&var-host=<HOSTNAME>",
  "drilldownTo": {
    "rede-n4-wan-dispositivo": "/d/rede-n4-wan-dispositivo?var-group=${group}&var-host=${host}&var-iface=Gi0%2F1"
  },
  "variables": [
    {
      "name": "group",
      "label": "Host Group",
      "type": "textbox",
      "default": "HG_AGENCIAS_ROUTERS",
      "hide": true
    },
    {
      "name": "host",
      "label": "Agência",
      "type": "query (mysql)",
      "note": "Dropdown por NOME da agência (unidade_negocio) -> valor=host. DS MySQL Network."
    }
  ],
  "panels": [
    {
      "file": "utils.js",
      "id": 1,
      "role": "utils",
      "title": "Header + Shared",
      "content": "<div id=\"bpc-header-root\"></div>"
    },
    {
      "file": "n4-ficha-table.json",
      "id": 207,
      "role": "content",
      "title": "Ficha da Agência"
    },
    {
      "file": "n4-stat-icmp.json",
      "id": 200,
      "role": "content",
      "title": "Disponibilidade"
    },
    {
      "file": "n4-stat-latency.json",
      "id": 201,
      "role": "content",
      "title": "Latência ICMP"
    },
    {
      "file": "n4-stat-loss.json",
      "id": 202,
      "role": "content",
      "title": "Packet Loss"
    },
    {
      "file": "n4-stat-cpu.json",
      "id": 203,
      "role": "content",
      "title": "CPU"
    },
    {
      "file": "n4-stat-mem.json",
      "id": 204,
      "role": "content",
      "title": "Memória livre"
    },
    {
      "file": "n4-stat-uptime.json",
      "id": 205,
      "role": "content",
      "title": "Uptime"
    },
    {
      "file": "n4-table-ifaces.json",
      "id": 206,
      "role": "content",
      "title": "Links WAN — Estado"
    },
    {
      "file": "n4-triggers.json",
      "id": 208,
      "role": "content",
      "title": "Problemas Activos"
    },
    {
      "file": "l4-n5-button.js",
      "id": 101,
      "role": "content",
      "title": "N5 Button",
      "content": "<div id=\"bpc-n5-btn\" style=\"height:100%\"></div>"
    },
    {
      "file": "n4-timeline-ifaces.json",
      "id": 210,
      "role": "content",
      "title": "Histórico (flaps)"
    },
    {
      "file": "l4-provider-context.js",
      "id": 211,
      "role": "content",
      "title": "Operadoras WAN — hub DMVPN",
      "content": "<div id=\"bpc-provider-ctx\"></div>"
    }
  ],
  "nativePanels": [
    {
      "title": "ICMP — Latência e Packet Loss",
      "type": "timeseries",
      "items": [
        "/ICMP response time/",
        "/ICMP loss/"
      ],
      "refIds": [
        "A",
        "B"
      ],
      "units": [
        "ms",
        "percent"
      ]
    },
    {
      "title": "WAN — Tráfego Recebido",
      "type": "timeseries",
      "items": [
        "/Interface.*(WAN|DMVPN|TUNEL|TUNNEL).*: Bits received/"
      ],
      "refIds": [
        "C"
      ],
      "units": [
        "bps"
      ]
    },
    {
      "title": "WAN — Tráfego Enviado",
      "type": "timeseries",
      "items": [
        "/Interface.*(WAN|DMVPN|TUNEL|TUNNEL).*: Bits sent/"
      ],
      "refIds": [
        "D"
      ],
      "units": [
        "bps"
      ]
    }
  ]
}
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT Unidade, Router, Status\nFROM (\n  SELECT\n  h.name AS Router,\n  COALESCE(MAX(CASE WHEN ht.tag='unidade_negocio' THEN ht.value END), h.name) AS Unidade,\n  CASE\n    WHEN SUM(CASE WHEN t.description = 'Cisco IOS: Unavailable by ICMP ping'\n              AND t.value = 1 THEN 1 ELSE 0 END) > 0 THEN 1\n    WHEN SUM(CASE WHEN t.description IN (\n              'Cisco IOS: High ICMP ping loss',\n              'Cisco IOS: High ICMP ping response time')\n              AND t.value = 1 THEN 1 ELSE 0 END) > 0 THEN 2\n    ELSE 3\n  END AS Status\n  FROM hosts h\n  INNER JOIN host_inventory hi ON h.hostid = hi.hostid\n  INNER JOIN hosts_groups hg ON h.hostid = hg.hostid\n  LEFT JOIN host_tag ht ON h.hostid = ht.hostid\n  INNER JOIN functions f ON h.hostid = (\n    SELECT i2.hostid FROM items i2 WHERE i2.itemid = f.itemid LIMIT 1)\n  INNER JOIN triggers t ON f.triggerid = t.triggerid\n  WHERE hg.groupid = 24\n  AND hi.location_lat IS NOT NULL AND hi.location_lat != ''\n  AND ('${agencia:raw}' = '__Todas__' OR h.hostid IN (\n    SELECT hostid FROM host_tag WHERE tag = 'unidade_negocio' AND value = '${agencia:raw}'))\n  GROUP BY h.hostid, h.name\n) sub\nWHERE Status < 3\nORDER BY Status ASC, Unidade ASC",
          "refId": "A",

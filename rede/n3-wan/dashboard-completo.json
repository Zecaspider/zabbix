        \u003cdiv class=\"bpc-card\" style=\"--card-accent:#22C55E\"\u003e\n         O ::before gera a barra de 3px colorida no topo do card.       */\n      .bpc-card {\n        background:    rgba(14, 20, 60, 0.55);\n        border:        1px solid rgba(255,255,255,0.08);\n        border-radius: 10px;\n        padding:       13px 15px 11px;\n        position:      relative;\n        overflow:      hidden;\n        transition:    border-color .15s, background .15s;\n      }\n      .bpc-card::before {\n        content:       \u0027\u0027;\n        position:      absolute;\n        top:0; left:0; right:0;\n        height:        3px;\n        background:    var(--card-accent, var(--bpc-cyan));\n        border-radius: 10px 10px 0 0;\n        z-index:       1;\n      }\n      .bpc-card:hover {\n        border-color: rgba(0,180,216,0.22);\n        background:   rgba(14,20,60,0.70);\n      }\n\n      /* 芒聰聙芒聰聙 Estados dos cards 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         .state-ok  芒聠聮 sem override (herda o estilo base do card)\n         .state-warn芒聠聮 borda esquerda 脙垄mbar\n         .state-down芒聠聮 borda esquerda vermelha + fundo levemente vermelho */\n      .bpc-card.state-ok   {}\n      .bpc-card.state-warn {\n        border-color: rgba(240,165,0,0.28);\n        border-left:  2px solid rgba(240,165,0,0.70);\n      }\n      .bpc-card.state-down {\n        border-color: rgba(239,68,68,0.28);\n        border-left:  2px solid rgba(239,68,68,0.75);\n        background:   rgba(239,68,68,0.04);\n      }\n\n      /* 芒聰聙芒聰聙 Layout helpers 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Utilit脙隆rios de flexbox para compor o interior dos cards.       */\n      .bpc-flex     { display:flex; align-items:center; }\n      .bpc-flex-col { display:flex; flex-direction:column; }\n      .bpc-gap-4    { gap:4px;  }\n      .bpc-gap-8    { gap:8px;  }\n      .bpc-gap-12   { gap:12px; }\n\n      /* 芒聰聙芒聰聙 Tipografia 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         .bpc-label    芒聠聮 r脙鲁tulo pequeno uppercase (ex: \"Total\", \"Down\")\n         .bpc-value-lg 芒聠聮 n脙潞mero grande principal (ex: total de hosts)\n         .bpc-value-md 芒聠聮 n脙潞mero m脙漏dio (ex: down, warn)\n         .bpc-value-sm 芒聠聮 valor pequeno (ex: RTT, Loss)                  */\n      .bpc-label    { font-size:.67rem; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--bpc-mute); }\n      .bpc-value-lg { font-size:1.80rem; font-weight:700; color:#E6EDF3; line-height:1; }\n      .bpc-value-md { font-size:1.10rem; font-weight:600; color:#E6EDF3; line-height:1; }\n      .bpc-value-sm { font-size:.85rem;  font-weight:600; color:#E6EDF3; line-height:1; }\n\n      /* 芒聰聙芒聰聙 Classes de cor de estado 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Aplicar directamente a qualquer elemento de texto.             */\n      .bpc-ok   { color:var(--bpc-ok);   }\n      .bpc-warn { color:var(--bpc-warn); }\n      .bpc-crit { color:var(--bpc-crit); }\n      .bpc-info { color:var(--bpc-info); }\n      .bpc-mute { color:var(--bpc-mute); }\n\n      /* 芒聰聙芒聰聙 Pills 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Pastilha colorida de estado (ex: \"OK\", \"Degradado\", \"Down\").\n         .bpc-pill.down inclui anima脙搂脙拢o de pulse para chamar a aten脙搂脙拢o.  */\n      .bpc-pill {\n        font-size:.65rem; font-weight:700; letter-spacing:.05em;\n        text-transform:uppercase; padding:2px 9px;\n        border-radius:10px; border:1px solid transparent;\n        white-space:nowrap; line-height:1.6;\n      }\n      .bpc-pill.ok   { background:rgba(34,197,94,0.10);  color:var(--bpc-ok);   border-color:rgba(34,197,94,0.25); }\n      .bpc-pill.warn { background:rgba(240,165,0,0.10);  color:var(--bpc-warn); border-color:rgba(240,165,0,0.28); }\n      .bpc-pill.down { background:rgba(239,68,68,0.10);  color:var(--bpc-crit); border-color:rgba(239,68,68,0.28);\n                       animation:bpc-pulse-pill 1.2s ease-in-out infinite; }\n      @keyframes bpc-pulse-pill {\n        0%,100% { box-shadow:0 0 0 0   rgba(239,68,68,0.45); }\n        50%     { box-shadow:0 0 0 4px rgba(239,68,68,0);    }\n      }\n\n      /* 芒聰聙芒聰聙 Skeleton loader 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Anima脙搂脙拢o de shimmer enquanto os dados carregam.                */\n      .bpc-skeleton {\n        background:      linear-gradient(90deg,rgba(255,255,255,0.04) 25%,rgba(255,255,255,0.09) 50%,rgba(255,255,255,0.04) 75%);\n        background-size: 200% 100%;\n        animation:       bpc-shimmer 1.4s infinite;\n        border-radius:   4px;\n      }\n      @keyframes bpc-shimmer {\n        0%   { background-position: 200%  0; }\n        100% { background-position:-200%  0; }\n      }\n\n      /* 芒聰聙芒聰聙 Auxiliares 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         .bpc-divider   芒聠聮 separador vertical subtil entre colunas\n         .bpc-timestamp 芒聠聮 data/hora de actualiza脙搂脙拢o no rodap脙漏 do card   */\n      .bpc-divider   { width:1px; align-self:stretch; flex-shrink:0; background:rgba(255,255,255,0.07); }\n      .bpc-timestamp { font-size:.58rem; color:rgba(255,255,255,0.18); text-align:right; margin-top:4px; }\n\n      /* 芒聰聙芒聰聙 Mini bar (histograma de actividade) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Representa脙搂脙拢o visual de hist脙鲁rico de valores (ex: RTT).\n         Cada segmento tem altura proporcional ao valor relativo.        */\n      .bpc-mini-bar { display:flex; align-items:flex-end; gap:2px; height:22px; margin-top:8px; }\n      .bpc-bar-seg  { flex:1; border-radius:2px 2px 0 0; background:var(--card-accent,var(--bpc-cyan));\n                      opacity:.45; min-height:2px; transition:opacity .2s; }\n      .bpc-card:hover .bpc-bar-seg { opacity:.68; }\n\n      /* 芒聰聙芒聰聙 Erro inline 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Bloco de erro vis脙颅vel dentro de um card quando a API falha.    */\n      .bpc-error-msg {\n        display:flex; align-items:center; gap:6px;\n        font-size:.70rem; color:rgba(239,68,68,0.85);\n        background:rgba(239,68,68,0.07);\n        border-left:2px solid rgba(239,68,68,0.35);\n        border-radius:0 5px 5px 0;\n        padding:4px 8px; margin-top:6px;\n      }\n\n      /* 芒聰聙芒聰聙 Status bar global 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Barra de resumo \"OK: N 脗路 Degradado: N 脗路 Cr脙颅tico: N\"            */\n      .bpc-status-bar  { display:flex; align-items:center; gap:8px; padding:4px 0 8px; flex-wrap:wrap; }\n      .bpc-status-pill {\n        display:flex; align-items:center; gap:5px;\n        font-size:.67rem; font-weight:600; letter-spacing:.05em; text-transform:uppercase;\n        padding:3px 10px; border-radius:20px; border:1px solid transparent; white-space:nowrap;\n      }\n      .bpc-status-pill.ok   { background:rgba(34,197,94,0.08);  color:var(--bpc-ok);   border-color:rgba(34,197,94,0.20); }\n      .bpc-status-pill.warn { background:rgba(240,165,0,0.08);  color:var(--bpc-warn); border-color:rgba(240,165,0,0.22); }\n      .bpc-status-pill.crit { background:rgba(239,68,68,0.08);  color:var(--bpc-crit); border-color:rgba(239,68,68,0.22); }\n      .bpc-status-dot  { width:6px; height:6px; border-radius:50%; background:currentColor; flex-shrink:0; }\n      .bpc-status-sep  { width:1px; height:14px; background:rgba(255,255,255,0.12); margin:0 2px; flex-shrink:0; }\n\n    `;\n    document.head.appendChild(s);\n    if (window.BPC?.log) BPC.log(\u0027CSS global injectado (\u0027 + CFG_META.version + \u0027)\u0027);\n  }\n\n\n  // 芒聰聙芒聰聙 CSS de Pulse / bordas de estado 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n  //\n  //  Gerado a partir de CFG_PULSE (BLOCO 1).\n  //  enabled:false 芒聠聮 bordas est脙隆ticas (sem anima脙搂脙拢o, recomendado para NOC 24h)\n  //  enabled:true  芒聠聮 anima脙搂脙拢o de glow pulsante\n\n  if (!document.getElementById(\u0027bpc-pulse-css\u0027)) {\n    const p = CFG_PULSE;\n    const T = CFG_THEME;\n    const s = document.createElement(\u0027style\u0027);\n    s.id = \u0027bpc-pulse-css\u0027;\n\n    if (!p.enabled) {\n      // Bordas est脙隆ticas 芒聙聰 mais limpo para uso cont脙颅nuo\n      s.textContent = [\n        \u0027.bpc-card.state-ok   {}\u0027,\n        \u0027.bpc-card.state-warn { border-color:rgba(240,165,0,0.30); border-left:2px solid rgba(240,165,0,0.70); }\u0027,\n        \u0027.bpc-card.state-down { border-color:rgba(239,68,68,0.30); border-left:2px solid rgba(239,68,68,0.75); background:rgba(239,68,68,0.04); }\u0027,\n      ].join(\u0027\\n\u0027);\n      document.head.appendChild(s);\n      if (window.BPC?.log) BPC.log(\u0027Pulse: bordas est脙隆ticas (enabled=false)\u0027);\n    } else {\n      // Glow animado 芒聙聰 gerado dinamicamente a partir de CFG_PULSE e CFG_THEME\n      const hex = v =\u003e Math.round(Math.max(0, Math.min(1, v)) * 255).toString(16).padStart(2, \u00270\u0027);\n      const wS = Math.max(p.minSpeedSec, p.speed.warn) + \u0027s\u0027;\n      const cS = Math.max(p.minSpeedSec, p.speed.crit) + \u0027s\u0027;\n      s.textContent = `\n        @keyframes bpc-warn {\n          0%,100%{ border-color:${T.warn}44; box-shadow:0 0 0 0 ${T.warn}${hex(p.intensity.warn)}; }\n          50%    { border-color:${T.warn};   box-shadow:0 0 10px 2px ${T.warn}${hex(p.intensity.warn)}; }\n        }\n        @keyframes bpc-down {\n          0%,100%{ border-color:${T.crit}55; box-shadow:0 0 0 0 ${T.crit}${hex(p.intensity.crit)}; background:rgba(239,68,68,0.03); }\n          50%    { border-color:${T.crit};   box-shadow:0 0 14px 3px ${T.crit}${hex(p.intensity.crit)}; background:rgba(239,68,68,0.07); }\n        }\n        .bpc-card.state-warn{ border:${p.borderWidth} solid ${T.warn}60; border-radius:${p.borderRadius}; animation:bpc-warn ${wS} ease-in-out infinite; }\n        .bpc-card.state-down{ border:${p.borderWidth} solid ${T.crit}70; border-radius:${p.borderRadius}; animation:bpc-down ${cS} ease-in-out infinite; }\n      `;\n      document.head.appendChild(s);\n      if (window.BPC?.log) BPC.log(\u0027Pulse: animado 芒聙聰 warn:\u0027 + wS + \u0027 crit:\u0027 + cS);\n    }\n  }\n\n\n  // 芒聰聙芒聰聙 CSS do Header NOC 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n  //\n  //  Gerado a partir de CFG_SIZES e CFG_THEME (BLOCO 1).\n  //\n  //  NOTA v8: padding controlado por CFG_SIZES.header.padding.\n  //  Manter 芒聣陇12px vertical para n脙拢o expandir o painel Grafana.\n  //  Sem position:relative ou overflow:hidden no wrapper 芒聙聰 evita expans脙拢o.\n  //  Sem elementos com position:absolute 芒聙聰 evita que o browser expanda\n  //  o container para acomodar conte脙潞do \"fora do fluxo\".\n\n  if (!document.getElementById(\u0027bpc-header-css\u0027)) {\n    const Z = CFG_SIZES;\n    const s = document.createElement(\u0027style\u0027);\n    s.id = \u0027bpc-header-css\u0027;\n    s.textContent = `\n\n      /* 芒聰聙芒聰聙 Wrapper do header 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         Gradiente horizontal navy 芒聠聮 navy2 芒聠聮 navy com linha superior cyan */\n      .bpc-noc-hdr {\n        display:       flex;\n        align-items:   center;\n        gap:           16px;\n        background:    linear-gradient(90deg, ${CFG_THEME.navy} 0%, ${CFG_THEME.navy2} 50%, ${CFG_THEME.navy} 100%);\n        border:        1px solid rgba(0,180,216,0.14);\n        border-top:    ${Z.header.borderTopW} solid rgba(0,180,216,0.40);\n        border-radius: 10px;\n        padding:       ${Z.header.padding};\n        height:        100%;\n        box-sizing:    border-box;\n        font-family:   \u0027Inter\u0027,\u0027Segoe UI\u0027,sans-serif;\n      }\n\n      /* 芒聰聙芒聰聙 Log脙鲁tipo 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         .bpc-noc-logo-fallback 芒聠聮 exibido quando a imagem falha (onerror) */\n      .bpc-noc-logo          { height:${Z.logo.height}px; flex-shrink:0; }\n      .bpc-noc-logo-fallback {\n        height:${Z.logo.height}px; width:52px; flex-shrink:0;\n        background:rgba(255,255,255,0.04);\n        border:1px dashed rgba(255,255,255,0.12);\n        border-radius:7px; display:flex; align-items:center;\n        justify-content:center; font-size:10px; font-weight:800;\n        color:rgba(255,255,255,0.28); letter-spacing:1px;\n      }\n\n      /* 芒聰聙芒聰聙 Centro 芒聙聰 t脙颅tulo e subt脙颅tulo 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         \u003cem\u003e dentro do t脙颅tulo 芒聠聮 cor dourada (nocLabel)                  */\n      .bpc-noc-center { flex:1; text-align:center; }\n      .bpc-noc-title  {\n        font-size:${Z.title.size}; font-weight:800; letter-spacing:${Z.title.letterSpacing};\n        text-transform:uppercase; color:#fff; line-height:1;\n      }\n      .bpc-noc-title em { color:var(--bpc-gold, ${CFG_THEME.gold}); font-style:normal; }\n      .bpc-noc-sub    {\n        font-size:${Z.subtitle.size}; color:rgba(255,255,255,0.22);\n        letter-spacing:.14em; text-transform:uppercase; margin-top:4px;\n      }\n\n      /* 芒聰聙芒聰聙 Rel脙鲁gio 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n         D脙颅gitos com tabular-nums para evitar saltos visuais ao mudar    */\n      .bpc-noc-right { text-align:right; flex-shrink:0; }\n      .bpc-noc-time  {\n        font-size:${Z.clock.timeSize}; font-weight:800; color:var(--bpc-cyan, ${CFG_THEME.cyan});\n        letter-spacing:3px; display:block;\n        font-variant-numeric:tabular-nums; line-height:1;\n      }\n      .bpc-noc-date  {\n        font-size:${Z.clock.dateSize}; color:rgba(255,255,255,0.22);\n        margin-top:3px; text-transform:capitalize;\n      }\n\n    `;\n    document.head.appendChild(s);\n    if (window.BPC?.log) BPC.log(\u0027CSS header injectado (\u0027 + CFG_META.version + \u0027)\u0027);\n  }\n\n})(); // fim BLOCO 2\n\n\n// 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬\n//\n//  芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴 芒聳聢芒聳聢芒聲聴      芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴  芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴  芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴     芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴\n//  芒聳聢芒聳聢芒聲聰芒聲聬芒聲聬芒聳聢芒聳聢芒聲聴芒聳聢芒聳聢芒聲聭     芒聳聢芒聳聢芒聲聰芒聲聬芒聲聬芒聲聬芒聳聢芒聳聢芒聲聴芒聳聢芒聳聢芒聲聰芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺 芒聳聢芒聳聢芒聲聰芒聲聬芒聲聬芒聲聬芒聳聢芒聳聢芒聲聴    芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聳聢芒聳聢芒聲聴\n//  芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聰芒聲聺芒聳聢芒聳聢芒聲聭     芒聳聢芒聳聢芒聲聭   芒聳聢芒聳聢芒聲聭芒聳聢芒聳聢芒聲聭      芒聳聢芒聳聢芒聲聭   芒聳聢芒聳聢芒聲聭      芒聳聞芒聳聢芒聳聢芒聳聢芒聲聰芒聲聺\n//  芒聳聢芒聳聢芒聲聰芒聲聬芒聲聬芒聳聢芒聳聢芒聲聴芒聳聢芒聳聢芒聲聭     芒聳聢芒聳聢芒聲聭   芒聳聢芒聳聢芒聲聭芒聳聢芒聳聢芒聲聭      芒聳聢芒聳聢芒聲聭   芒聳聢芒聳聢芒聲聭      芒聳聙芒聳聙芒聲聬芒聲聬芒聲聺\n//  芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聰芒聲聺芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴芒聲職芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聰芒聲聺芒聲職芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聴 芒聲職芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聳聢芒聲聰芒聲聺      芒聳聢芒聳聢芒聲聴\n//  芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺 芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺 芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺  芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺  芒聲職芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聺       芒聲職芒聲聬芒聲聺\n//\n//  HTML DO CABE脙聡ALHO NOC\n//\n//  Aguarda o elemento #bpc-header-root no DOM (injectado pelo painel\n//  Grafana \"Text\") e preenche-o com o cabe脙搂alho.\n//\n//  Cont脙漏m:\n//    芒聙垄 Fun脙搂脙拢o renderHeader(el) 芒聠聮 gera o HTML do cabe脙搂alho\n//    芒聙垄 Fun脙搂脙拢o renderClock()    芒聠聮 actualiza hora + data a cada segundo\n//    芒聙垄 Polling para #bpc-header-root (timeout 10s)\n//\n//  Todo o texto e apar脙陋ncia v脙陋m de CFG_HEADER, CFG_SIZES, CFG_THEME (BLOCO 1).\n//\n// 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬\n\n(function initHeader() {\n\n  // 芒聰聙芒聰聙 renderClock 芒聙聰 actualiza #bpc-clock-time e #bpc-clock-date 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n\n  function renderClock() {\n    const now = new Date();\n    const pad = n =\u003e String(n).padStart(2, \u00270\u0027);\n    const tEl = document.getElementById(\u0027bpc-clock-time\u0027);\n    const dEl = document.getElementById(\u0027bpc-clock-date\u0027);\n    if (!tEl || !dEl) return;\n    tEl.textContent =\n      pad(now.getHours()) + \u0027:\u0027 + pad(now.getMinutes()) + \u0027:\u0027 + pad(now.getSeconds());\n    dEl.textContent =\n      CFG_CLOCK.days[now.getDay()] + \u0027, \u0027 +\n      now.getDate() + \u0027 de \u0027 +\n      CFG_CLOCK.months[now.getMonth()] + \u0027 de \u0027 +\n      now.getFullYear();\n  }\n\n\n  // 芒聰聙芒聰聙 renderHeader 芒聙聰 gera o HTML e inicia o rel脙鲁gio 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙\n  //\n  //  Estrutura:\n  //    .bpc-noc-hdr\n  //    芒聰聹芒聰聙芒聰聙 [logo ou fallback textual]\n  //    芒聰聹芒聰聙芒聰聙 .bpc-noc-center  (t脙颅tulo + subt脙颅tulo)\n  //    芒聰聰芒聰聙芒聰聙 .bpc-noc-right   (rel脙鲁gio + data)\n\n  function renderHeader(el) {\n    const C = CFG_HEADER;\n    const Z = CFG_SIZES;\n\n    // Log脙鲁tipo: tenta carregar a imagem; se falhar, mostra fallback textual\n    const logoHTML = C.logoUrl\n      ? `\u003cimg src=\"${C.logoUrl}\"\n              height=\"${Z.logo.height}\"\n              class=\"bpc-noc-logo\"\n              onerror=\"this.style.display=\u0027none\u0027;this.nextElementSibling.style.display=\u0027flex\u0027\"\u003e\n         \u003cdiv class=\"bpc-noc-logo-fallback\" style=\"display:none\"\u003e${C.title}\u003c/div\u003e`\n      : `\u003cdiv class=\"bpc-noc-logo-fallback\"\u003e${C.title}\u003c/div\u003e`;\n\n    el.innerHTML = `\n      \u003cdiv class=\"bpc-noc-hdr\"\u003e\n\n        \u003c!-- Log脙鲁tipo --\u003e\n        \u003cdiv style=\"display:flex;align-items:center;gap:10px;flex-shrink:0\"\u003e\n          ${logoHTML}\n        \u003c/div\u003e\n\n        \u003c!-- T脙颅tulo + Subt脙颅tulo --\u003e\n        \u003cdiv class=\"bpc-noc-center\"\u003e\n          \u003cdiv class=\"bpc-noc-title\"\u003e\n            ${C.title} \u0026nbsp;|\u0026nbsp; \u003cem\u003e${C.nocLabel}\u003c/em\u003e\n          \u003c/div\u003e\n          ${C.subtitle ? `\u003cdiv class=\"bpc-noc-sub\"\u003e${C.subtitle}\u003c/div\u003e` : \u0027\u0027}\n        \u003c/div\u003e\n\n        \u003c!-- Rel脙鲁gio --\u003e\n        \u003cdiv class=\"bpc-noc-right\"\u003e\n          \u003cspan class=\"bpc-noc-time\" id=\"bpc-clock-time\"\u003e--:--:--\u003c/span\u003e\n          \u003cdiv  class=\"bpc-noc-date\" id=\"bpc-clock-date\"\u003e芒聙娄\u003c/div\u003e\n        \u003c/div\u003e\n\n      \u003c/div\u003e`;\n\n    // Inicia o rel脙鲁gio (limpa timer anterior se o header for re-renderizado)\n    if (window._bpc_clock_interval) clearInterval(window._bpc_clock_interval);\n    renderClock();\n    window._bpc_clock_interval = setInterval(renderClock, 1000);\n\n    if (window.BPC?.log) BPC.log(\u0027Header renderizado (\u0027 + CFG_META.version + \u0027)\u0027);\n  }\n\n\n  // 芒聰聙芒聰聙 Aguardar #bpc-header-root no DOM 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒
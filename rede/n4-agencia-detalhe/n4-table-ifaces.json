{
  "type": "table",
  "title": "Links WAN — Estado",
  "datasource": {
    "type": "alexanderzobnin-zabbix-datasource",
    "uid": "ffo8sp8zllog0e"
  },
  "transparent": true,
  "targets": [
    {
      "datasource": {
        "type": "alexanderzobnin-zabbix-datasource",
        "uid": "ffo8sp8zllog0e"
      },
      "functions": [],
      "group": {
        "filter": "${group}"
      },
      "host": {
        "filter": "${host}"
      },
      "item": {
        "filter": "/Interface.*(WAN|DMVPN|TUNEL|TUNNEL).*: Operational status/"
      },
      "options": {
        "showDisabledItems": false
      },
      "queryType": "0",
      "refId": "A",
      "resultFormat": "time_series"
    }
  ],
  "transformations": [
    {
      "id": "timeSeriesTable",
      "options": {
        "A": {
          "stat": "lastNotNull",
          "timeField": "Time"
        }
      }
    },
    {
      "id": "organize",
      "options": {
        "excludeByName": {
          "host": true,
          "item_key": true
        },
        "renameByName": {
          "item": "Interface",
          "Trend #A": "Estado / histórico"
        },
        "indexByName": {
          "item": 0,
          "Trend #A": 1
        }
      }
    }
  ],
  "fieldConfig": {
    "defaults": {
      "color": {
        "mode": "thresholds"
      },
      "custom": {
        "align": "auto",
        "cellOptions": {
          "type": "auto"
        },
        "filterable": false
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "Interface"
        },
        "properties": [
          {
            "id": "custom.width",
            "value": 520
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Estado / histórico"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "sparkline",
              "hideValue": false
            }
          },
          {
            "id": "mappings",
            "value": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "UP",
                    "color": "green",
                    "index": 0
                  },
                  "2": {
                    "text": "DOWN",
                    "color": "red",
                    "index": 1
                  }
                }
              }
            ]
          },
          {
            "id": "thresholds",
            "value": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 2
                }
              ]
            }
          },
          {
            "id": "custom.width",
            "value": 420
          }
        ]
      }
    ]
  },
  "options": {
    "showHeader": true,
    "cellHeight": "md"
  }
}
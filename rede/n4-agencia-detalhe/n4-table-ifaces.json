{
  "type": "table",
  "title": "Links WAN — Estado",
  "datasource": {
    "type": "alexanderzobnin-zabbix-datasource",
    "uid": "ffo8sp8zllog0e"
  },
  "transparent": true,
  "targets": [
    {
      "datasource": {
        "type": "alexanderzobnin-zabbix-datasource",
        "uid": "ffo8sp8zllog0e"
      },
      "functions": [],
      "group": {
        "filter": "${group}"
      },
      "host": {
        "filter": "${host}"
      },
      "item": {
        "filter": "/Interface.*(WAN|DMVPN|TUNEL|TUNNEL).*: Operational status/"
      },
      "options": {
        "showDisabledItems": false
      },
      "queryType": "0",
      "refId": "A",
      "resultFormat": "time_series"
    }
  ],
  "transformations": [
    {
      "id": "reduce",
      "options": {
        "reducers": [
          "lastNotNull"
        ],
        "includeTimeField": false,
        "mode": "seriesToRows"
      }
    },
    {
      "id": "organize",
      "options": {
        "renameByName": {
          "Field": "Interface",
          "Last *": "Estado",
          "Last": "Estado"
        }
      }
    }
  ],
  "fieldConfig": {
    "defaults": {
      "color": {
        "mode": "thresholds"
      },
      "custom": {
        "align": "auto",
        "cellOptions": {
          "type": "auto"
        }
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "Estado"
        },
        "properties": [
          {
            "id": "mappings",
            "value": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "UP",
                    "color": "green",
                    "index": 0
                  },
                  "2": {
                    "text": "DOWN",
                    "color": "red",
                    "index": 1
                  }
                }
              }
            ]
          },
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background"
            }
          },
          {
            "id": "custom.align",
            "value": "center"
          }
        ]
      }
    ]
  },
  "options": {
    "showHeader": true,
    "cellHeight": "sm"
  }
}
{
  "type": "state-timeline",
  "title": "Uplinks — Estado (Operacional)",
  "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "ffo8sp8zllog0e" },
  "fieldConfig": {
    "defaults": {
      "color": { "mode": "thresholds" },
      "custom": { "lineWidth": 0, "fillOpacity": 85, "spanNulls": false, "insertNulls": false },
      "mappings": [
        { "type": "value", "options": {
          "1": { "text": "UP",   "color": "green" },
          "2": { "text": "DOWN", "color": "red"   }
        }}
      ],
      "thresholds": { "mode": "absolute", "steps": [
        { "color": "red",   "value": null },
        { "color": "green", "value": 1    }
      ]}
    },
    "overrides": []
  },
  "options": {
    "mergeValues": true,
    "showValue": "auto",
    "alignValue": "center",
    "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
  },
  "targets": [
    {
      "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "ffo8sp8zllog0e" },
      "functions": [],
      "group": { "filter": "${group}" },
      "host": { "filter": "${switch}" },
      "item": { "filter": "/.*Uplink.*Operational status/" },
      "options": { "showDisabledItems": false },
      "queryType": "0",
      "refId": "A",
      "resultFormat": "time_series"
    }
  ],
  "transparent": true
}

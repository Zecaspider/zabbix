  "pluginVersion": "12.4.2",
  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT\n  h.host AS `Host`,\n  h.name AS `Nome`,\n  (SELECT ip FROM interface WHERE hostid=h.hostid AND main=1 LIMIT 1) AS `IP`,\n  (SELECT (SELECT hu.value FROM history_uint hu WHERE hu.itemid=i.itemid ORDER BY hu.clock DESC LIMIT 1)\n     FROM items i WHERE i.hostid=h.hostid AND i.key_='icmpping' AND i.status=0 LIMIT 1) AS `Ping`,\n  (SELECT ROUND((UNIX_TIMESTAMP() - (SELECT hu.clock FROM history_uint hu WHERE hu.itemid=i.itemid ORDER BY hu.clock DESC LIMIT 1))/60)\n     FROM items i WHERE i.hostid=h.hostid AND i.key_='agent.ping' AND i.status=0 LIMIT 1) AS `Agente (min)`,\n  (SELECT COUNT(*) FROM items i WHERE i.hostid=h.hostid AND i.key_ LIKE 'service.info%' AND i.status=0) AS `Svc Win`,\n  (SELECT COUNT(DISTINCT t.triggerid) FROM triggers t\n     JOIN functions f ON f.triggerid=t.triggerid JOIN items i2 ON i2.itemid=f.itemid\n     WHERE i2.hostid=h.hostid AND t.value=1 AND t.status=0) AS `Triggers`,\n  (SELECT t3.description FROM triggers t3\n     JOIN functions f3 ON f3.triggerid=t3.triggerid JOIN items i4 ON i4.itemid=f3.itemid\n     WHERE i4.hostid=h.hostid AND t3.value=1 AND t3.status=0\n     ORDER BY t3.priority DESC, t3.lastchange DESC LIMIT 1) AS `Problema`\nFROM hosts h\nJOIN host_tag ht ON ht.hostid=h.hostid AND ht.tag='servico' AND ht.value='$servico'\nWHERE h.status=0\nORDER BY `Triggers` DESC, `Host`",
      "refId": "A",
      "sql": { "columns": [ { "parameters": [], "type": "function" } ], "groupBy": [ { "property": { "type": "string" }, "type": "groupBy" } ], "limit": 50 }
    }
  ]

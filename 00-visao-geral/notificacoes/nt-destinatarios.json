      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT TRIM(CONCAT(COALESCE(u.name,''), ' ', COALESCE(u.surname,''))) AS Utilizador, u.username AS Login, mt.name AS Via, mt.status AS Mediatype, m.sendto AS Destino, m.active AS 'Media do utilizador'\nFROM media m\nJOIN users u ON u.userid = m.userid\nJOIN media_type mt ON mt.mediatypeid = m.mediatypeid\nORDER BY u.username, mt.name",

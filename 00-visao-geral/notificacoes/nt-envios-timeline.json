  "pluginVersion": "12.4.2",
  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code",
      "format": "time_series",
      "rawQuery": true,
      "rawSql": "SELECT FROM_UNIXTIME(FLOOR(a.clock / 3600) * 3600) AS time,\n  CASE a.status WHEN 1 THEN 'Enviado' WHEN 2 THEN 'Falhado' WHEN 0 THEN 'Em fila' ELSE 'Novo' END AS metric,\n  COUNT(*) AS value\nFROM alerts a\nWHERE a.alerttype = 0 AND $__unixEpochFilter(a.clock)\nGROUP BY 1, 2\nORDER BY 1",
      "refId": "A"
    }
  ],
  "title": "Notificações por hora e estado",
  "transparent": true,
  "type": "timeseries"

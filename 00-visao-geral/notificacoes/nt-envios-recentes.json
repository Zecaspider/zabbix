  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code",
      "format": "table",
      "rawQuery": true,
      "rawSql": "SELECT FROM_UNIXTIME(a.clock) AS Hora, COALESCE(mt.name, '?') AS Via, a.sendto AS Destinatario, a.subject AS Assunto, a.status AS Estado, a.retries AS Tentativas, NULLIF(a.error, '') AS Erro\nFROM alerts a\nLEFT JOIN media_type mt ON mt.mediatypeid = a.mediatypeid\nWHERE a.alerttype = 0 AND $__unixEpochFilter(a.clock)\nORDER BY a.clock DESC\nLIMIT 200",
      "refId": "A"
    }
  ],
  "title": "Envios recentes (janela do dashboard, máx. 200)",
  "transparent": true,
  "type": "table"

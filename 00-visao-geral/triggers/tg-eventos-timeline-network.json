  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "cfo3cgypdrdvkf" },
      "editorMode": "code", "format": "time_series", "rawQuery": true,
      "rawSql": "SELECT FROM_UNIXTIME(FLOOR(e.clock / 3600) * 3600) AS time,\n  CASE e.severity WHEN 5 THEN 'Desastre' WHEN 4 THEN 'Alta' WHEN 3 THEN 'Media' WHEN 2 THEN 'Aviso' WHEN 1 THEN 'Info' ELSE 'N/class' END AS metric,\n  COUNT(*) AS value\nFROM events e\nWHERE e.source = 0 AND e.object = 0 AND e.value = 1 AND $__unixEpochFilter(e.clock)\nGROUP BY 1, 2\nORDER BY 1",
      "refId": "A"
    }
  ],
  "title": "NETWORK — problemas abertos por hora e severidade",
  "transparent": true,
  "type": "timeseries"

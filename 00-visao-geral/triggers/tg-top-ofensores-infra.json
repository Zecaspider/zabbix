  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "afor1g5862fb4c" },
      "editorMode": "code", "format": "table", "rawQuery": true,
      "rawSql": "SELECT COUNT(DISTINCT e.eventid) AS eventos,\n  MIN(h.name) AS host,\n  t.description AS trigger_nome\nFROM events e\nJOIN triggers t ON t.triggerid = e.objectid\nJOIN functions f ON f.triggerid = t.triggerid\nJOIN items i ON i.itemid = f.itemid\nJOIN hosts h ON h.hostid = i.hostid\nWHERE e.source = 0 AND e.object = 0 AND e.value = 1 AND $__unixEpochFilter(e.clock)\nGROUP BY t.triggerid, t.description\nORDER BY eventos DESC\nLIMIT 15",
      "refId": "A"
    }
  ],
  "title": "INFRA — top 15 triggers ofensoras (flappers) na janela",
  "transparent": true,
  "type": "table"
}

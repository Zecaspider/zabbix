  "targets": [
    {
      "datasource": { "type": "mysql", "uid": "cfo3cgypdrdvkf" },
      "editorMode": "code", "format": "table", "rawQuery": true,
      "rawSql": "SELECT ROUND((UNIX_TIMESTAMP() - p.clock) / 86400) AS dias,\n  p.severity AS sev,\n  MIN(h.name) AS host,\n  p.name AS problema\nFROM problem p\nJOIN triggers t ON t.triggerid = p.objectid\nJOIN functions f ON f.triggerid = t.triggerid\nJOIN items i ON i.itemid = f.itemid\nJOIN hosts h ON h.hostid = i.hostid\nWHERE p.source = 0 AND p.object = 0 AND p.r_eventid IS NULL AND p.severity >= 2\nGROUP BY p.eventid, p.clock, p.severity, p.name\nORDER BY dias DESC\nLIMIT 20",
      "refId": "A"
    }
  ],
  "title": "NETWORK — 20 problemas activos mais antigos (backlog)",
  "transparent": true,
  "type": "table"
}

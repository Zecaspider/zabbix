months[now.getMonth()] + \u0027 de \u0027 +\n      now.getFullYear();\n  }\n\n\n  // 脙垄脗聰脗聙脙垄脗聰脗聙 renderHeader 脙垄脗聙脗聰 gera o HTML e inicia o rel脙聝脗鲁gio 脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙脙垄脗聰脗聙\n  //\n  //  Estrutura:\n  //    .bpc-noc-hdr\n  //    脙垄脗聰脗聹脙垄脗聰脗聙脙垄脗聰脗聙 [logo ou fallback textual]\n  //    脙垄脗聰脗聹脙垄脗聰脗聙脙垄脗聰脗聙 .bpc-noc-center  (t脙聝脗颅tulo + subt脙聝脗颅tulo)\n  //    脙垄脗聰脗聰脙垄脗聰脗聙脙垄脗聰脗聙 .bpc-noc-right   (rel脙聝脗鲁gio + data)\n\n  function renderHeader(el) {\n    const C = CFG_HEADER;\n    const Z = CFG_SIZES;\n\n    // Log脙聝脗鲁tipo: tenta carregar a imagem; se falhar, mostra fallback textual\n    const logoHTML = C.logoUrl\n      ? `\u003cimg src=\"${C.logoUrl}\"\n              height=\"${Z.logo.height}\"\n              class=\"bpc-noc-logo\"\n              onerror=\"this.style.display=\u0027none\u0027;this.nextElementSibling.style.display=\u0027flex\u0027\"\u003e\n         \u003cdiv class=\"bpc-noc-logo-fallback\" style=\"display:none\"\u003e${C.title}\u003c/div\u003e`\n      : `\u003cdiv class=\"bpc-noc-logo-fallback\"\u003e${C.title}\u003c/div\u003e`;\n\n    el.innerHTML = `\n      \u003cdiv class=\"bpc-noc-hdr\"\u003e\n\n        \u003c!-- Log脙聝脗鲁tipo --\u003e\n        \u003cdiv style=\"display:flex;align-items:center;gap:10px;flex-shrink:0\"\u003e\n          ${logoHTML}\n        \u003c/div\u003e\n\n        \u003c!-- T脙聝脗颅tulo + Subt脙聝脗颅tulo --\u003e\n        \u003cdiv class=\"bpc-noc-center\"\u003e\n          \u003cdiv class=\"bpc-noc-title\"\u003e\n            ${C.title} \u0026nbsp;|\u0026nbsp; \u003cem\u003e${C.nocLabel}\u003c/em\u003e\n          \u003c/div\u003e\n          ${C.subtitle ? `\u003cdiv class=\"bpc-noc-sub\"\u003e${C.subtitle}\u003c/div\u003e` : \u0027\u0027}\n        \u003c/div\u003e\n\n        \u003c!-- Rel脙聝脗鲁gio --\u003e\n        \u003cdiv class=\"bpc-noc-right\"\u003e\n          \u003cspan class=\"bpc-noc-time\" id=\"bpc-clock-time\"
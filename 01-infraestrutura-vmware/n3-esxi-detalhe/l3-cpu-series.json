{
  "type": "timeseries",
  "title": "CPU Usage",
  "description": "CPU utilização % ao longo do tempo — ESXi $hostid",
  "datasource": {"type": "alexanderzobnin-zabbix-datasource", "uid": "3_KgG43nz"},
  "targets": [
    {
      "refId": "A",
      "queryType": "0",
      "group":  {"filter": "BPC/DOMINIO/01 Virtualizacao"},
      "host":   {"filter": "$hostid"},
      "item":   {"filter": "CPU usage in percent"},
      "datasource": {"type": "alexanderzobnin-zabbix-datasource", "uid": "3_KgG43nz"},
      "resultFormat": "time_series"
    }
  ],
  "options": {
    "tooltip": {"mode": "single", "sort": "none"},
    "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "last"]}
  },
  "fieldConfig": {
    "defaults": {
      "unit": "percent",
      "min": 0,
      "max": 100,
      "color": {"mode": "thresholds"},
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green",  "value": null},
          {"color": "yellow", "value": 75},
          {"color": "red",    "value": 90}
        ]
      },
      "custom": {
        "lineWidth": 2,
        "fillOpacity": 10,
        "spanNulls": false,
        "thresholdsStyle": {"mode": "line+area"}
      }
    },
    "overrides": []
  }
}
